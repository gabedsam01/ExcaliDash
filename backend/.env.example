# Backend Environment Variables
PORT=8000
NODE_ENV=production
APP_URL=http://localhost:6767
# ExcaliDash is PostgreSQL-only. Under docker compose the DB host is the
# 'postgres' service name instead of localhost (e.g. ...@postgres:5432/...).
DATABASE_URL=postgresql://excalidash:generate_with_quickstart@localhost:5432/excalidash?schema=public
DIRECT_URL=postgresql://excalidash:generate_with_quickstart@localhost:5432/excalidash?schema=public
POSTGRES_PASSWORD=generate_with_quickstart
FRONTEND_URL=http://localhost:6767
# Keep disabled unless traffic always comes through a trusted reverse proxy.
TRUST_PROXY=false
AUTH_MODE=local
JWT_SECRET=generate_with_quickstart
CSRF_SECRET=generate_with_quickstart
# HMAC secret for API keys. Required for direct production starts. The Docker
# entrypoint can generate and persist it for single-instance deployments.
API_KEY_SECRET=generate_with_quickstart
RUNTIME_DATA_DIR=./data

# Payload and import limits (MiB unless the name is a count)
MAX_UPLOAD_MB=250
MAX_JSON_BODY_MB=100
MAX_URLENCODED_BODY_MB=100
MAX_SOCKET_PAYLOAD_MB=100
MAX_IMPORT_DRAWING_MB=100
MAX_IMPORT_MANIFEST_MB=10
MAX_IMPORT_TOTAL_EXTRACTED_MB=500
MAX_DATA_URL_MB=100
MAX_IMPORT_ARCHIVE_ENTRIES=10000
MAX_IMPORT_COLLECTIONS=2000
MAX_IMPORT_DRAWINGS=10000

# --- Snapshot retention + smart snapshots ---------------------------------
# ExcaliDash keeps only the latest N snapshots per drawing by default to prevent
# PostgreSQL growth from large Excalidraw files with embedded images. Saves are
# optimized to avoid creating large snapshots on every autosave.
# Keep at most N snapshots per drawing (<= 0 disables automatic retention).
MAX_SNAPSHOTS_PER_DRAWING=15
# Prune old snapshots right after creating a new one.
SNAPSHOT_PRUNE_ON_SAVE=true
# Run a one-shot count-based prune across all drawings at startup (off by default).
SNAPSHOT_PRUNE_ON_STARTUP=false
# Minimum seconds between snapshots for the same drawing (smart snapshot gating).
SNAPSHOT_MIN_INTERVAL_SECONDS=300
# Snapshot on every scene save (defeats interval gating; off by default).
SNAPSHOT_ON_EVERY_SAVE=false
# Force a snapshot on explicit version/checkpoint events (manual save / restore).
SNAPSHOT_FORCE_ON_VERSION_CHANGE=true
# Respond to the save before the snapshot write/prune finishes (keeps saves fast).
SNAPSHOT_ASYNC=true

# --- Server-side image optimization (optional dependency: sharp) ----------
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_OPTIMIZATION_MAX_WIDTH=1920
IMAGE_OPTIMIZATION_MAX_HEIGHT=1920
IMAGE_OPTIMIZATION_WEBP_QUALITY=82
IMAGE_OPTIMIZATION_JPEG_QUALITY=82
IMAGE_OPTIMIZATION_PNG_COMPRESSION_LEVEL=9
# Files smaller than this many bytes are left untouched.
IMAGE_OPTIMIZATION_MIN_BYTES=200000
IMAGE_OPTIMIZATION_CACHE_ENABLED=true

# --- Save performance logging ---------------------------------------------
# Log a single structured line (sizes/counts/timings only — never payload
# content) when a save exceeds SAVE_PERF_SLOW_MS.
SAVE_PERF_LOG_ENABLED=true
SAVE_PERF_SLOW_MS=1000

# --- Optional Redis speed layer (recommended) -----------------------------
# PostgreSQL is always the source of truth. Redis only caches hot drawings +
# listing metadata and coordinates saves (advisory lock + cross-replica
# snapshot coalescing). If REDIS_ENABLED=false, or Redis is unreachable, the
# backend logs a warning and runs on PostgreSQL alone. No secrets and no
# payloads above REDIS_MAX_VALUE_BYTES are ever stored in Redis. See docs/redis.md.
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379
REDIS_PREFIX=excalidash:
# Default TTL (seconds) for generic cached values.
REDIS_CACHE_TTL_SECONDS=300
# TTL for the hot per-drawing cache.
REDIS_DRAWING_CACHE_TTL_SECONDS=600
# TTL for cached listing/metadata responses.
REDIS_METADATA_CACHE_TTL_SECONDS=300
# Advisory per-drawing save lock TTL (short + self-healing).
REDIS_SAVE_LOCK_TTL_SECONDS=30
# Enable advisory save lock + cross-replica snapshot coalescing.
REDIS_SAVE_QUEUE_ENABLED=true
# Values larger than this many bytes are never written to Redis (10 MiB).
REDIS_MAX_VALUE_BYTES=10485760
# Set to "true" to log cache hit/miss + save-lock events at debug level.
# REDIS_DEBUG=false

# --- Optional local (on-volume) file storage ------------------------------
# NO object storage (S3/R2/MinIO) is used — ExcaliDash stays self-hosted.
# This is a scaffold for offloading large embedded images onto a local volume
# in a future release; it is OFF by default and does not affect the save path.
LOCAL_FILE_STORAGE_ENABLED=false
LOCAL_FILE_STORAGE_DIR=/app/data/files

# Optional Feature Flags
# Set to "true" or "1" to enable:
# ENABLE_PASSWORD_RESET=false
# ENABLE_REFRESH_TOKEN_ROTATION=true
# ENABLE_AUDIT_LOGGING=false

# When FRONTEND_URL uses https://, the backend will redirect plain-HTTP requests
# to HTTPS by default. Set to "false" when your external gateway (Nginx, Traefik,
# Caddy, etc.) already enforces HTTPS and you want to prevent double-redirect
# loops or want to delegate HTTPS enforcement entirely to the outer proxy.
# ENFORCE_HTTPS_REDIRECT=true

# Migration control
# For PostgreSQL in Kubernetes, prefer running migrations once via a Job/init container
# and set RUN_MIGRATIONS=false on the main Deployment to avoid concurrent migrates.
# RUN_MIGRATIONS=true
# MIGRATION_LOCK_TIMEOUT_SECONDS=120

# Upgrade safety
# If true, disables the production onboarding gate that blocks API usage until
# "Choose Authentication Mode" is completed. Not recommended.
# DISABLE_ONBOARDING_GATE=true

# Update notifier (GitHub release checks)
# If false, disables outbound requests to the GitHub API (update checks will be unavailable).
# UPDATE_CHECK_OUTBOUND=true
# Optional GitHub token to increase API rate limits (public repo scopes are fine).
# UPDATE_CHECK_GITHUB_TOKEN=

# One-time bootstrap setup code (first admin registration)
# BOOTSTRAP_SETUP_CODE_TTL_MS=900000
# BOOTSTRAP_SETUP_CODE_MAX_ATTEMPTS=10

# OIDC Configuration (required when AUTH_MODE=hybrid or AUTH_MODE=oidc_enforced)
# OIDC_PROVIDER_NAME=OIDC
# OIDC_ISSUER_URL=http://localhost:8080/realms/excalidash
# Optional: internal backend-only discovery URL for split-horizon networking.
# Example: browser uses localhost while the backend discovers through an internal service.
# OIDC_DISCOVERY_URL=http://localhost:8080/realms/excalidash
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=http://localhost:6767/api/auth/oidc/callback
# OIDC_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_post
# OIDC_SCOPES=openid profile email
# OIDC_EMAIL_CLAIM=email
# OIDC_EMAIL_VERIFIED_CLAIM=email_verified
# OIDC_GROUPS_CLAIM=groups
# Comma-separated OIDC groups/roles that should have ADMIN privileges.
# When configured, OIDC users are promoted/demoted on authenticated requests.
# OIDC_ADMIN_GROUPS=excalidash-admins,platform-admins
# OIDC_REQUIRE_EMAIL_VERIFIED=true
# OIDC_JIT_PROVISIONING=true
# OIDC_FIRST_USER_ADMIN=true
