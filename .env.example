# Docker Compose defaults
FRONTEND_PORT=6767

# --- PostgreSQL (database) ---
# ExcaliDash is PostgreSQL-only. These power the bundled "postgres" service in
# docker-compose.yml and are composed into DATABASE_URL below.
# IMPORTANT: change POSTGRES_PASSWORD to a strong value before deploying.
POSTGRES_DB=excalidash
POSTGRES_USER=excalidash
POSTGRES_PASSWORD=change_me_strong_password
# Host port the local database is published on (docker-compose.yml only).
POSTGRES_PORT=5432

# Connection string used by the backend (Prisma). With the bundled postgres
# service the host is the service name "postgres". To use an external/managed
# PostgreSQL instead, set DATABASE_URL to your provider's URL (the POSTGRES_*
# values above are then only used by the local postgres service, which you can
# remove from the compose file).
DATABASE_URL=postgresql://excalidash:change_me_strong_password@postgres:5432/excalidash?schema=public

PORT=8000
NODE_ENV=production
AUTH_MODE=local
FRONTEND_URL=http://localhost:6767

# Keep false for direct/local access. Set to 1 only when every request reaches
# the backend through the trusted frontend Nginx/proxy path.
TRUST_PROXY=false

# Leave false when an external gateway already redirects HTTP to HTTPS.
ENFORCE_HTTPS_REDIRECT=false

# Optional for a single backend container: the Docker entrypoint generates and
# persists secrets in the backend volume. Set both for portable deployments.
JWT_SECRET=
CSRF_SECRET=

# Backend payload/import limits (MiB unless the name is a count).
MAX_UPLOAD_MB=250
MAX_JSON_BODY_MB=100
MAX_URLENCODED_BODY_MB=100
MAX_SOCKET_PAYLOAD_MB=100
MAX_IMPORT_DRAWING_MB=100
MAX_IMPORT_MANIFEST_MB=10
MAX_IMPORT_TOTAL_EXTRACTED_MB=500
MAX_DATA_URL_MB=100
MAX_IMPORT_ARCHIVE_ENTRIES=10000
MAX_IMPORT_COLLECTIONS=2000
MAX_IMPORT_DRAWINGS=10000

# Frontend Nginx runtime configuration.
BACKEND_URL=backend:8000
NGINX_CLIENT_MAX_BODY_SIZE=250M
NGINX_PROXY_CONNECT_TIMEOUT=300s
NGINX_PROXY_SEND_TIMEOUT=300s
NGINX_PROXY_READ_TIMEOUT=300s
NGINX_WEBSOCKET_READ_TIMEOUT=3600s
NGINX_WEBSOCKET_SEND_TIMEOUT=3600s

# docker-compose.prod.yml image overrides.
EXCALIDASH_BACKEND_IMAGE=zimengxiong/excalidash-backend
EXCALIDASH_FRONTEND_IMAGE=zimengxiong/excalidash-frontend
EXCALIDASH_IMAGE_TAG=latest
