# ExcaliDash V2 quickstart configuration
HTTP_PORT=6767
APP_URL=http://localhost:6767
FRONTEND_URL=http://localhost:6767
AUTH_MODE=local
TRUST_PROXY=true
ENFORCE_HTTPS_REDIRECT=false

POSTGRES_DB=excalidash
POSTGRES_USER=excalidash
POSTGRES_PASSWORD=generate_with_quickstart

JWT_SECRET=generate_with_quickstart
CSRF_SECRET=generate_with_quickstart
API_KEY_SECRET=generate_with_quickstart

EXCALIDASH_BACKEND_TAG=backend-latest
EXCALIDASH_FRONTEND_TAG=frontend-latest

MCP_ENABLED=true
MCP_MIN_DRAWING_SCORE=95
MCP_MAX_REPAIR_ATTEMPTS=5
MCP_ALLOW_LOW_SCORE_DRAFT=true
MCP_LIBRARY_MODE=curated
MCP_DEFAULT_LIBRARY_MODE=curated

MAX_UPLOAD_MB=250
MAX_JSON_BODY_MB=100
MAX_URLENCODED_BODY_MB=100
MAX_SOCKET_PAYLOAD_MB=100

# Snapshot retention + smart saves (keep large Excalidraw files from ballooning
# the DrawingSnapshot table). See docs/postgres.md.
MAX_SNAPSHOTS_PER_DRAWING=15
SNAPSHOT_PRUNE_ON_SAVE=true
SNAPSHOT_PRUNE_ON_STARTUP=false
SNAPSHOT_MIN_INTERVAL_SECONDS=300
SNAPSHOT_ON_EVERY_SAVE=false
SNAPSHOT_FORCE_ON_VERSION_CHANGE=true
SNAPSHOT_ASYNC=true

# Server-side image optimization (optional dependency: sharp)
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_OPTIMIZATION_MAX_WIDTH=1920
IMAGE_OPTIMIZATION_MAX_HEIGHT=1920
IMAGE_OPTIMIZATION_WEBP_QUALITY=82
IMAGE_OPTIMIZATION_JPEG_QUALITY=82
IMAGE_OPTIMIZATION_PNG_COMPRESSION_LEVEL=9
IMAGE_OPTIMIZATION_MIN_BYTES=200000
IMAGE_OPTIMIZATION_CACHE_ENABLED=true

# Save performance logging (sizes/counts/timings only — never payload content)
SAVE_PERF_LOG_ENABLED=true
SAVE_PERF_SLOW_MS=1000

# --- Optional Redis speed layer (recommended) -----------------------------
# PostgreSQL stays the source of truth. Redis caches hot drawings + metadata
# and coordinates saves. If Redis is unavailable the app falls back to
# PostgreSQL. The docker-compose quickstart ships a redis service; set
# REDIS_ENABLED=false to run without it. See docs/redis.md.
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
REDIS_PREFIX=excalidash:
REDIS_CACHE_TTL_SECONDS=300
REDIS_DRAWING_CACHE_TTL_SECONDS=600
REDIS_METADATA_CACHE_TTL_SECONDS=300
REDIS_SAVE_LOCK_TTL_SECONDS=30
REDIS_SAVE_QUEUE_ENABLED=true
REDIS_MAX_VALUE_BYTES=10485760

LIBRARY_PUBLIC_SEARCH_ENABLED=true
LIBRARY_AUTO_REFRESH_ON_START=true

NGINX_CLIENT_MAX_BODY_SIZE=250M
NGINX_PROXY_CONNECT_TIMEOUT=300s
NGINX_PROXY_SEND_TIMEOUT=300s
NGINX_PROXY_READ_TIMEOUT=300s
NGINX_WEBSOCKET_READ_TIMEOUT=3600s
NGINX_WEBSOCKET_SEND_TIMEOUT=3600s
